.bar-pane .button-close:hover {
	-fx-opacity: 0.5;
}

.control-pane .button-play:hover {
	-fx-opacity: 0.5;
}

.control-pane .button-next:hover {
	-fx-opacity: 0.5;
}

.control-pane .button-last:hover {
	-fx-opacity: 0.5;
}

.play-list .scroll-bar:vertical .increment-button {
	-fx-background-color: transparent ;
	-fx-background-radius: 0.0em ;
} 

.play-list .scroll-bar:vertical .decrement-button {
	-fx-background-color: transparent ;
	-fx-background-radius: 0.0em ;
} 