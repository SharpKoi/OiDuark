.pane .button-play:hover {
	-fx-opacity: 0.5;
}

.pane .button-play:pressed {
	-fx-opacity: 0.5;
}

.pane .button-play:release {
	-fx-image: url(resources/images/icons/pause_100px.png);
	-fx-opacity: 1;
}

.pane .button-next:hover {
	-fx-opacity: 0.5;
	-fx-background-radius: 50;
}

.pane .button-next:pressed {
	-fx-opacity: 0.5;
	-fx-background-radius: 50;
}

.pane .button-last:hover {
	-fx-opacity: 0.5;
	-fx-background-radius: 50;
}

.pane .button-last:pressed {
	-fx-opacity: 0.5;
	-fx-background-radius: 50;
}